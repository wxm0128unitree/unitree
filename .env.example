# ====================================================================
# 宇树机器人出入库管理系统 - 部署环境变量模板
# ====================================================================
# 复制为 .env 后再修改：
#     cp .env.example .env
# ====================================================================

# ---------- JWT 密钥（必改！强烈建议用下面命令生成随机 64 位字符串） ------
# 生成命令：   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_请用命令生成_然后粘贴到这里

# ---------- 管理员账号（首次启动自动创建） ---------
ADMIN_NAME=王曦明
ADMIN_PHONE=13083401281
ADMIN_PASSWORD=111111

# ---------- 是否允许注册（所有用户自助注册） ---------
# 1 = 允许任意人注册（默认）；0 = 关闭注册（手动开账户）
ALLOW_REGISTER=1

# ---------- 数据库（默认 SQLite，落在容器 /data 目录，已通过卷持久化） ---------
# 一般无需修改。若要切 MySQL/Postgres，把 DATABASE_URL 设成：
#   DATABASE_URL=mysql+pymysql://user:pwd@host:3306/dbname
DB_PATH=/data/robot_inventory.db
